<common:PluginUserControlBase x:Class="SteamShortcuts.Presentation.SteamGameActionsLauncher"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SteamShortcuts.Presentation"
             xmlns:common="clr-namespace:PluginsCommon"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Button x:Name="PART_Button"
                Content="&#xED71;" TextBlock.FontFamily="{DynamicResource FontIcoFont}"
                TextBlock.FontSize="20"
                Click="OnButtonClick">

            <Button.ContextMenu>
                <ContextMenu x:Name="PART_ContextMenu">

                    <!-- Steam Client Actions -->
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameLibraryDetails}" Click="OnViewDetails"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameProperties}" Click="OnGameProperties"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameSteamInput}" Click="OnControllerConfig"/>

                    <Separator/>

                    <!-- Web -->
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameStorePageDescription}" Click="OnStorePage"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameCommunityHubDescription}" Click="OnCommunityHub"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameDiscussionsDescription}" Click="OnDiscussions"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameGuidesDescription}" Click="OnGuides"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGameAchievementsDescription}" Click="OnAchievements"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemComponentNewsDescription}" Click="OnNews"/>
                    <MenuItem Header="{DynamicResource LOCSteam_Viewer_MenuItemGamePointsShopDescription}" Click="OnPointsShop"/>

                </ContextMenu>
            </Button.ContextMenu>

        </Button>
    </Grid>
</common:PluginUserControlBase>
