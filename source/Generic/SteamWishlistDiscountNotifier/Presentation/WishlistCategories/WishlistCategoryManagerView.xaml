<UserControl x:Class="SteamWishlistDiscountNotifier.Presentation.WishlistCategories.WishlistCategoryManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SteamWishlistDiscountNotifier.Presentation.WishlistCategories"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Create section -->
        <StackPanel Orientation="Horizontal">
            <TextBox Width="200"
                     Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Add"
                    Margin="5,0,0,0"
                    Command="{Binding CreateCategoryCommand}" />
        </StackPanel>

        <!-- Categories list -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Categories}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Delete"
                                Margin="5,0,0,0"
                                Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
