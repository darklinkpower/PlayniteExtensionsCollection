<UserControl x:Class="SteamWishlistDiscountNotifier.Presentation.WishlistCategories.WishlistItemCategoryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SteamWishlistDiscountNotifier.Presentation.WishlistCategories"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Categories"
                   Foreground="White"
                   FontWeight="Bold"
                   FontSize="14"/>

        <!-- Category list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Tri-state checkbox -->
                            <CheckBox Content="{Binding Name}"
                                      IsThreeState="True"
                                      IsChecked="{Binding State, Mode=TwoWay}"
                                      VerticalAlignment="Center"/>

                            <!-- Optional: exclusive toggle -->
                            <Button Grid.Column="1"
                                    Content="Only"
                                    Margin="5,0,0,0"
                                    Padding="5,0"
                                    Command="{Binding DataContext.SetExclusiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Batch actions -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Clear All"
                    Margin="0,0,5,0"
                    Command="{Binding ClearAllCommand}" />

            <Button Content="Apply"
                    Margin="0,0,5,0"
                    Command="{Binding ApplyCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
