    <sys:String x:Key="LOCReview_Viewer_Reaction_24_Desc">Das absolut Beste! Zumindest bis jetzt.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_25_Name">Schön</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_25_Desc">Worte können es nicht beschreiben, also muss es diese Auszeichnung.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_26_Name">Hilfreich</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_26_Desc">You're a credit to the team.</sys:String>
