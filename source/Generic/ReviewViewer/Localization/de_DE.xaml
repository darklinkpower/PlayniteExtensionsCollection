    <sys:String x:Key="LOCReview_Viewer_Reaction_27_Desc">Dies ist nicht das erste großer Kunstwerke und wird wahrscheinlich nicht das letzte sein.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_28_Name">Witzig</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_28_Desc">ROFL. Oder zumindest LOL.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_29_Name">Einhundert</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_29_Desc">Totally, absolutely, completely agree.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_30_Name">Lebensretter</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_30_Desc">You've saved me from my tight spot.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_31_Name">Perfekt</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_31_Desc">Couldn't be more correct or on point.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_32_Name">Plus One</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_32_Desc">I agree. I think everyone should know that I agree.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_33_Name">Clever</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_33_Desc">Ingenuity at its finest.</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_34_Name">Reines Gold</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_34_Desc">So valuable and shiny I want to put it in a box</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_35_Name">Wholesome</sys:String>
    <sys:String x:Key="LOCReview_Viewer_Reaction_35_Desc">So gemütlich, so warm.</sys:String>

